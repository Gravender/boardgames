{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    ".next",
    ".expo",
    "expo-plugins",
    ".turbo",
    ".cache",
    ".bun",
    ".pnpm-store",
    "coverage",
    "dist",
    "node_modules",
    "apps/native/android",
    "apps/native/ios",
    "packages/playwright-web/playwright",
    "packages/playwright-web/playwright-report",
    "packages/playwright-web/test-results",
    "packages/playwright-web/blob-report"
  ],
  "plugins": ["eslint", "oxc", "react", "typescript", "unicorn"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "react-in-jsx-scope": "off",
    "eslint/no-await-in-loop": "off",
    "eslint/no-shadow": "off"
  }
}
