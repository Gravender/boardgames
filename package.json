{
  "name": "board-games",
  "private": true,
  "engines": {
    "node": ">=22.21.0",
    "pnpm": ">=10.15.1"
  },
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "db:push": "turbo -F @board-games/db push",
    "db:createviews": "turbo -F @board-games/db createviews",
    "db:studio": "turbo -F @board-games/db studio",
    "db:seed": "turbo -F @board-games/db seed",
    "dev": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @board-games/nextjs...",
    "fmt": "turbo run format --continue",
    "fmt:fix": "turbo run format:fix --continue",
    "format": "turbo run format --continue",
    "format:fix": "turbo run format:fix --continue",
    "lint": "turbo run lint --continue",
    "lint:fix": "turbo run lint:fix --continue",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "pnpm lint:ws",
    "typecheck": "turbo run typecheck --filter=!@board-games/expo",
    "ui-add": "turbo run ui-add",
    "e2e": "docker compose -f .devcontainer/docker-compose.yml up -d playwright && docker compose -f .devcontainer/docker-compose.yml exec -T playwright pnpm --dir /workspace --filter @board-games/playwright-web e2e"
  },
  "devDependencies": {
    "@turbo/gen": "^2.7.3",
    "dotenv-cli": "^10.0.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "turbo": "^2.7.3",
    "typescript": "catalog:"
  }
}
