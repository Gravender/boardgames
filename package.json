{
  "name": "board-games",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=22.21.0",
    "pnpm": "^10.19.0"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "oxlint && oxfmt --write",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "db:push": "turbo -F @board-games/db push",
    "db:studio": "turbo -F @board-games/db studio",
    "db:seed": "turbo -F @board-games/db seed",
    "db:start": "turbo -F @board-games/db db:start",
    "db:watch": "turbo -F @board-games/db db:watch",
    "db:stop": "turbo -F @board-games/db db:stop",
    "db:down": "turbo -F @board-games/db db:down",
    "db:migrate": "turbo -F @board-games/db migrate",
    "dev": "turbo watch dev --continue",
    "dev:web": "turbo watch dev dev:spotlight -F web...",
    "fmt": "turbo run format --continue",
    "fmt:fix": "turbo run format:fix --continue",
    "format": "turbo run format --continue",
    "format:fix": "turbo run format:fix --continue",
    "lint": "turbo run lint --continue",
    "lint:fix": "turbo run lint:fix --continue",
    "postinstall": "pnpm lint:ws",
    "prepare": "husky",
    "typecheck": "turbo run typecheck --filter=!native",
    "test:api": "turbo run test --filter=@board-games/api",
    "test:shared": "turbo run test --filter=@board-games/shared",
    "test:web": "turbo run test --filter=web",
    "ui-add": "turbo run ui-add",
    "e2e": "turbo -F @board-games/playwright-web e2e"
  },
  "devDependencies": {
    "@board-games/config": "workspace:*",
    "@turbo/gen": "^2.9.14",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "zod": "catalog:"
  },
  "lint-staged": {
    "*": [
      "oxlint",
      "oxfmt --write"
    ]
  }
}
