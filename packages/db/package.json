{
  "name": "@board-games/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./src/schema/index.ts"
    },
    "./zodSchema": {
      "types": "./dist/zodSchema.d.ts",
      "default": "./src/zodSchema/index.ts"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "default": "./src/constants/index.ts"
    },
    "./views": {
      "types": "./dist/views.d.ts",
      "default": "./src/views/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "db:start": "docker compose up -d",
    "db:watch": "docker compose up",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down",
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "oxfmt --check .",
    "lint": "oxlint --report-unused-disable-directives",
    "push": "bun --env-file=../../.env x drizzle-kit push && bun --env-file=../../.env x tsx src/migrations/applyCreateViews.ts",
    "migrate": "bun --env-file=../../.env x drizzle-kit migrate",
    "generate": "bun --env-file=../../.env x drizzle-kit generate",
    "seed": "bun --env-file=../../.env x tsx src/seeding/seed.ts",
    "studio": "bun --env-file=../../.env x drizzle-kit studio",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "format:fix": "oxfmt .",
    "lint:fix": "oxlint --fix --report-unused-disable-directives"
  },
  "dependencies": {
    "@vercel/postgres": "^0.10.0",
    "drizzle-orm": "1.0.0-beta.12-a5629fb",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.17.2",
    "tsx": "^4.19.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@board-games/config": "workspace:*",
    "@faker-js/faker": "^9.6.0",
    "@types/d3": "^7.4.3",
    "@types/pg": "^8.16.0",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "drizzle-kit": "1.0.0-beta.12-a5629fb",
    "typescript": "catalog:"
  }
}
