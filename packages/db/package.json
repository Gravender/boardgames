{
  "name": "@board-games/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./src/schema/index.ts"
    },
    "./zodSchema": {
      "types": "./dist/zodSchema.d.ts",
      "default": "./src/zodSchema/index.ts"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "default": "./src/constants/index.ts"
    },
    "./views": {
      "types": "./dist/views.d.ts",
      "default": "./src/views/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "oxfmt --check .",
    "lint": "oxlint --report-unused-disable-directives",
    "push": "pnpm with-env drizzle-kit push",
    "createviews": "sh -c 'POSTGRES_CONTAINER_ID=\"$(docker compose -f ../../.devcontainer/docker-compose.yml ps -q postgres)\"; if [ -z \"$POSTGRES_CONTAINER_ID\" ]; then echo \"Could not determine postgres container ID from docker compose\"; exit 1; fi; docker exec -i \"$POSTGRES_CONTAINER_ID\" psql -X -v ON_ERROR_STOP=1 -U postgres -d games < src/migrations/0001_create_views.sql'",
    "migrate": "pnpm with-env drizzle-kit migrate",
    "generate": "pnpm with-env drizzle-kit generate",
    "seed": "pnpm with-env tsx src/seeding/seed.ts",
    "studio": "pnpm with-env drizzle-kit studio",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "dotenv -e ../../.env --",
    "format:fix": "oxfmt .",
    "lint:fix": "oxlint --fix --report-unused-disable-directives"
  },
  "dependencies": {
    "@vercel/postgres": "^0.10.0",
    "drizzle-orm": "1.0.0-beta.12-a5629fb",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.17.2",
    "tsx": "^4.19.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@board-games/tsconfig": "workspace:*",
    "@faker-js/faker": "^9.6.0",
    "@types/d3": "^7.4.3",
    "@types/pg": "^8.16.0",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "drizzle-kit": "1.0.0-beta.12-a5629fb",
    "typescript": "catalog:"
  }
}
