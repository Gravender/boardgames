{
  "name": "@board-games/ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./*": "./src/components/*.tsx",
    "./components/*": "./src/components/*.tsx",
    "./utils": "./src/lib/utils.ts",
    "./lib/utils": "./src/lib/utils.ts",
    "./lib/*": "./src/lib/*",
    "./hooks/*": "./src/hooks/*",
    "./hooks/use-mobile": "./src/hooks/use-mobile.tsx"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "oxfmt --check .",
    "lint": "oxlint --report-unused-disable-directives",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "ui-add": "bunx shadcn@latest add && oxfmt src",
    "format:fix": "oxfmt .",
    "lint:fix": "oxlint --fix --report-unused-disable-directives"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "class-variance-authority": "^0.7.0",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.513.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.65.0",
    "react-resizable-panels": "^4.8.0",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@board-games/config": "workspace:*",
    "@types/react": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "zod": "catalog:"
  }
}
