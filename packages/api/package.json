{
  "name": "@board-games/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "oxfmt --check .",
    "lint": "oxlint --report-unused-disable-directives",
    "test": "bun --env-file=../../.env x vitest",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "format:fix": "oxfmt .",
    "lint:fix": "oxlint --fix --report-unused-disable-directives"
  },
  "dependencies": {
    "@board-games/auth": "workspace:*",
    "@board-games/db": "workspace:*",
    "@board-games/shared": "workspace:*",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@trpc/server": "catalog:",
    "dotenv": "^17.2.2",
    "drizzle-plus": "1.0.0-rc.1",
    "luxon": "^3.7.2",
    "posthog-node": "^5.28.8",
    "superjson": "2.2.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@board-games/config": "workspace:*",
    "@types/luxon": "^3.7.1",
    "typescript": "catalog:",
    "vitest": "^3.2.4"
  }
}
