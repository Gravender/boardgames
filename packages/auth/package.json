{
  "name": "@board-games/auth",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./middleware": "./src/middleware.ts",
    "./client": "./src/client.ts",
    "./env": "./env.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "oxfmt --check .",
    "lint": "oxlint --report-unused-disable-directives .",
    "generate": "dotenv -e ../../.env -- pnpx @better-auth/cli generate --config script/auth-cli.ts --output ../db/src/auth-schema.ts",
    "typecheck": "tsc --noEmit",
    "format:fix": "oxfmt .",
    "lint:fix": "oxlint --fix --report-unused-disable-directives ."
  },
  "dependencies": {
    "@better-auth/expo": "catalog:",
    "@board-games/db": "workspace:*",
    "@react-email/components": "^0.4.0",
    "@t3-oss/env-core": "^0.13.8",
    "better-auth": "catalog:",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "resend": "^4.8.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-auth/cli": "catalog:",
    "@board-games/tsconfig": "workspace:*",
    "@types/react": "catalog:react19",
    "typescript": "catalog:"
  }
}
